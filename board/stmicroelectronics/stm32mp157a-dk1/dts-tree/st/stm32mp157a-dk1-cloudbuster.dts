/*
 * Cloudbuster custom device tree for STM32MP157A-DK1
 */
/dts-v1/;
#include "stm32mp157a-dk1.dts"

/ {
	model = "STMicroelectronics STM32MP157A-DK1 Cloudbuster";
	compatible = "st,stm32mp157a-dk1-cloudbuster", "st,stm32mp157a-dk1", "st,stm32mp157";

	gpio-keys {
		compatible = "gpio-keys";

		button-user1 {
			label = "User1";
			gpios = <&gpioa 14 1>;
			linux,code = <407>;
			wakeup-source;
		};

		button-user2 {
			label = "User2";
			gpios = <&gpioa 13 1>;
			linux,code = <412>;
			wakeup-source;
		};
	};
};

&adc {
	pinctrl-0 = <&adc12_usb_cc_pins_a>, <&adc12_ain_pins_a>;

	adc2: adc@100 {
		channel@6 {
			reg = <6>;
			st,min-sample-time-ns = <5000>;
		};
	};
};

&i2c5 {
    pinctrl-names = "default", "sleep";
    pinctrl-0 = <&i2c5_pins_a>;
    pinctrl-1 = <&i2c5_sleep_pins_a>;
    i2c-scl-rising-time-ns = <185>;
    i2c-scl-falling-time-ns = <20>;
    clock-frequency = <100000>;
    status = "okay";

    lcd: lcd@3e {
        compatible = "aip,aip31068";
        reg = <0x3e>;
        display-height-chars = <2>;
        display-width-chars = <16>;
    };
};
